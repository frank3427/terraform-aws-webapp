# AWS Configuration
aws_region = "us-west-2"

# Project Configuration
project_name = "webapp"
environment  = "production"

# Network Configuration
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24", "10.0.13.0/24"]
db_subnet_cidrs      = ["10.0.21.0/24", "10.0.22.0/24"]

# Instance Configuration
instance_type    = "t3.medium"
web_server_count = 3  # scale the web fleet here (1-20)
db_instance_type = "t3.large"

# AWS Key Pair (must exist in your AWS account)
key_name = "your-key-pair-name"

# Database Configuration
db_root_password        = "your-strong-root-password"
db_replication_user     = "replicator"
db_replication_password = "your-strong-replication-password"
db_app_password         = "your-strong-app-password"  # must differ from root password

# Bastion Host Configuration
bastion_instance_type = "t3.micro"
# REQUIRED: SSH access to the bastion. List your office/VPN CIDR ranges.
# 0.0.0.0/0 is rejected by validation.
bastion_allowed_cidrs = ["203.0.113.0/24"]

# HTTPS (optional)
# Request/import a certificate in AWS Certificate Manager (same region) and
# set its ARN here. The ALB will then serve HTTPS and redirect HTTP to HTTPS.
# acm_certificate_arn = "arn:aws:acm:us-west-2:123456789012:certificate/xxxx"

# Monitoring (Prometheus + Alertmanager + Grafana, see MONITORING.md)
enable_monitoring        = true
monitoring_instance_type = "t3.small"
# Email address for Prometheus alerts (confirm the SNS subscription email
# AWS sends after apply).
alert_email = "alerts@diasranch.com"

# EFS throughput: "elastic" (default) avoids burst-credit throttling on
# small filesystems; "bursting" is cheaper for large/lightly-used data.
# efs_throughput_mode = "elastic"

# Security toggles
enable_waf              = true   # AWS WAF managed rules on the ALB (~$10-15/mo)
alb_deletion_protection = true   # set false before terraform destroy

# Cost toggle: one shared NAT gateway instead of one per AZ (~$65/mo saved,
# outbound internet then depends on a single AZ)
# single_nat_gateway = true

# Pre-baked web AMI (see packer/README.md); empty = stock Ubuntu at boot
# web_ami_id = "ami-xxxxxxxxxxxxxxxxx"