# AWS Configuration
aws_region = "us-west-2"

# Project Configuration
project_name = "webapp"
environment  = "production"

# Network Configuration
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24", "10.0.13.0/24"]
db_subnet_cidrs      = ["10.0.21.0/24", "10.0.22.0/24"]

# Instance Configuration
instance_type    = "t3.medium"
db_instance_type = "t3.large"

# AWS Key Pair (must exist in your AWS account)
key_name = "your-key-pair-name"

# Database Configuration
db_root_password        = "your-strong-root-password"
db_replication_user     = "replicator"
db_replication_password = "your-strong-replication-password"

# Bastion Host Configuration
bastion_instance_type = "t3.micro"
bastion_allowed_cidrs = ["0.0.0.0/0"]  # Restrict this to your IP ranges for security